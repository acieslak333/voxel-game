# Build output
/build/
/out/
cmake-build-*/

# Fetched dependencies (pulled by CMake FetchContent at configure time)
/_deps/

# Compiled shader output (generated at build time)
*.spv

# Editor / IDE
.vscode/
.idea/
.vs/
*.swp
*~

# Python bytecode (scripts/, tools/)
__pycache__/
*.pyc

# Tools-launcher per-tool capture logs (tools/hub.py)
/tools/_hub_logs/
# Map-tool scratch renders (tools/genmap_tool.py, biome_tool.py)
/tools/_genmap.png
/tools/_biomemap.png
/tools/_genvox.bin
/tools/_genvox.bin.sea

# Runtime world saves (per-seed chunk data, generated at play time)
/saves/

# Debug capture output
/out_uipass.png
# Headless verification screenshots land at the repo root (`voxelgame --frames N
# --screenshot foo.png` during agent/CI checks) — never game content.
/*.png
/*.png.sea
# Feature-tool preview renders (tools/feature_tool.py)
/tools/_feature_previews/

# Local third-party checkouts / reference material (re-fetch, don't commit):
# the Blockbench MCP server clone and downloaded texture-pack references.
/tools/blockbench-mcp/
/reference/

# Claude Code local project config + installed skills (skills-lock.json is the
# committed manifest; the skill contents reinstall from it).
/.claude/

# OS cruft
.DS_Store
Thumbs.db
